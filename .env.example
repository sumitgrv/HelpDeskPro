# --- Core ---
APP_ENV=dev
SECRET_KEY=dev-secret

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/helpdeskpro

# --- Redis / RQ ---
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=helpdeskpro

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=helpdesk_docs

# --- Models ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=openai            # options: openai|hf-fallback
OPENAI_API_KEY=

# --- Search Fallback ---
FAKE_ENTERPRISE_SEARCH_URL=http://backend:8000/fallback/search
